{
    "name": "pepk-tool",
    "version": "1.0.0",
    "main": "src/main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.shinezzl.android.gp.pepk.tool",
        "mac": {
            "target": "dmg"
        },
        "extraResources": [
            {
                "from": "src/pepk/pepk.jar",
                "to": "pepk/pepk.jar"
            }
        ],
        "electronLanguages": [
            "en-US"
        ],
        "asar": true,
        "npmRebuild": false,
        "files": [
            "!**/*.md",
            "!**/test",
            "!**/tests",
            "!**/example",
            "!**/*.map"
        ]
    },
    "dependencies": {
        "axios": "^1.6.0"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^26.8.1"
    }
}